# Keep text files normalized in Git and checked out with LF in this repo.
* text=auto

# Enforce LF for source code and project files to avoid noisy line-ending diffs.
*.py text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
